# Copy to .env and fill in the channel(s) you want. Run with:
#   node --env-file=.env signals.mjs --paper

# ── Telegram (recommended for phone alerts) ──
# 1. In Telegram, message @BotFather → /newbot → copy the token here.
# 2. Message your new bot once (say "hi"), then visit:
#    https://api.telegram.org/bot<TOKEN>/getUpdates  → copy "chat":{"id":...}
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Discord (1-minute alternative) ──
# Server → Edit Channel → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL=

# ── Slack (optional) ──
SLACK_WEBHOOK_URL=
